# Environment Configuration Example
# Copy this file to .env and update with your actual values

# Environment
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/aiidigitalbank
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# API Configuration
API_TITLE=AI in Digital Banking
API_VERSION=1.0.0
API_DESCRIPTION=Intelligent Digital Banking Platform
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# External APIs
# Add any external API keys here

# Email Configuration (if needed)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tuantranscientist@gmail.com
SMTP_PASSWORD=your-app-password

# Logging
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# Feature Flags
ENABLE_RECOMMENDATIONS=true
ENABLE_FRAUD_DETECTION=true
ENABLE_CHURN_PREDICTION=true

# Model Configuration
MODEL_REFRESH_HOURS=24
RECOMMENDATION_LIMIT=5
CHURN_THRESHOLD=0.7

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_PERIOD_SECONDS=3600
